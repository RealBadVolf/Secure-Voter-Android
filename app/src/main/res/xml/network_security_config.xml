<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production: Only trust the election authority's CA + pinned certs -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">remote.securevote.gov</domain>
        <pin-set expiration="2027-01-01">
            <!-- Replace with actual SHA-256 pin of the sv-remote-gateway TLS cert -->
            <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
            <!-- Backup pin -->
            <pin digest="SHA-256">BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=</pin>
        </pin-set>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Debug: Allow local testing -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
